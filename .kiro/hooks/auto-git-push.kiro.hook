{
  "enabled": true,
  "name": "Auto Git Push",
  "description": "Faz commit e push automático para o GitHub sempre que um arquivo for salvo no workspace",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git commit -m \"auto: atualização automática $(date '+%Y-%m-%d %H:%M:%S')\" && git push origin HEAD"
  }
}